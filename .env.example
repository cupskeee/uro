# Environment for `uro serve` / the CLI. Copy to `.env` and fill in — `.env` is gitignored;
# this template is committed. Values are read from the process environment (export them, or
# `set -a; . ./.env; set +a` before running).

# --- Provider-credential encryption (D-47, docs/20) ---
# Key-encryption-key for provider credentials stored in the DB. MUST live OUTSIDE the DB.
# Required to store a credential via `uro provider add --api-key` / the /providers API / uro-loom;
# unset = credential storage is disabled (fail-closed).
# Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
URO_SECRET_KEY=

# --- LLM provider keys (for the `--provider` seed router; the DB registry can hold keys instead) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database (defaults to the docker-compose Postgres on host port 5433) ---
# URO_DATABASE_URL=postgresql://uro:uro@localhost:5433/uro
